{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "OTEL_METRICS_EXPORTER": "otlp"
  },
  "permissions": {
    "allow": [
      "Bash(rm -rf:*)",
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(npm run test:*)",
      "Bash(bun run:*)",
      "Read(~/.zshrc)"
    ],
    "deny": [
      "Bash(curl:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true
  },
  "statusLine": {
    "type": "command",
    "command": "bun x ccusage statusline"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd ./mastra-react && bun run format 2>/dev/null; bun run build && bun run test",
            "timeout": 300,
            "statusMessage": "format / build / test 実行中..."
          }
        ]
      }
    ]
  }
}
