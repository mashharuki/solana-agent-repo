# Solana DevNet RPC URL (必須)
# Alchemy, QuickNode, または公式エンドポイントを使用
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# Solana ネットワーク識別子 (devnet / mainnet-beta / testnet)
VITE_SOLANA_NETWORK=devnet

# Google Gemini API キー (solanaAgent で使用)
GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key_here

# Mastra LibSQL ストレージ URL
# 開発時: file:./mastra.db (デフォルト)
# 本番: Turso Cloud の libsql://... URL
MASTRA_LIBSQL_URL=file:./mastra.db

# Mastra Cloud Access Token (オプション: CloudExporter 使用時)
# MASTRA_CLOUD_ACCESS_TOKEN=your_token_here
