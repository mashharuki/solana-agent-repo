# ============================================================
# Solana Mastra AI Agent — 環境変数設定例
# このファイルをコピーして .env を作成してください。
# cp .env.example .env
# ============================================================

# --------------------------------------------------------
# Solana ネットワーク設定（フロントエンド・必須）
# --------------------------------------------------------

# Solana DevNet RPC URL（DAS API 対応推奨: QuickNode / Helius）
# 例: https://api.devnet.solana.com
# 例: https://<ENDPOINT>.solana-devnet.quiknode.pro/<TOKEN>/
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# 接続先ネットワーク識別子（devnet 固定）
VITE_SOLANA_NETWORK=devnet

# --------------------------------------------------------
# LLM API キー（バックエンド・いずれか必須）
# --------------------------------------------------------

# Anthropic Claude（推奨: claude-sonnet-4-6 等）
ANTHROPIC_API_KEY=

# Google Gemini（代替: gemini-2.0-flash-preview 等）
# GOOGLE_GENERATIVE_AI_API_KEY=

# --------------------------------------------------------
# Mastra ストレージ（本番 Vercel + Turso のみ必須）
# 未設定の場合はローカルファイル DB (file:./mastra.db) を使用
# --------------------------------------------------------

# Turso Cloud LibSQL URL（本番のみ）
# 例: libsql://<your-db>.turso.io
# MASTRA_LIBSQL_URL=

# Turso 認証トークン（本番のみ）
# MASTRA_LIBSQL_AUTH_TOKEN=

# --------------------------------------------------------
# Mastra Cloud（オプション）
# --------------------------------------------------------

# Mastra Cloud へのテレメトリ送信トークン（省略可）
# MASTRA_CLOUD_ACCESS_TOKEN=
